{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "CommonJS",
    "moduleResolution": "Node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist/preload-cjs",
    "rootDir": "src",
    "types": ["node", "electron"]
  },
  "include": ["src/preload/preload.ts", "src/shared/types.ts"]
}
